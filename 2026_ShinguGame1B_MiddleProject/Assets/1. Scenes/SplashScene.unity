  m_text: "\uAD11\uACFC\uBBFC\uC131 \uBC1C\uC791 \uBC18\uC751 \uACBD\uACE0\n\n\uADF9\uC18C\uC218\uC774\uB098
    \uBA87\uBA87 \uC0AC\uB78C\uB4E4\uC740 \uBE44\uB514\uC624 \uAC8C\uC784 \uB4F1\uC5D0\uC11C
